"""MCP Apps scaffold for {{ human_name }}.

Demonstrates the fastmcp >=3.2.4 app-tool addressing pattern:

- Hash injection via ``hash_tool`` / ``hashed_backend_name`` from
  ``fastmcp.server.providers.addressing``.
- ``_rewrite_spa_app_tool_calls``: validates and rewrites
  ``{{ python_module }}___<tool>`` source literals in the SPA HTML to the
  ``<hex_hash>_<tool>`` wire form at module import.
- ``_APP_TOOL_NAMES``: single source of truth for app-only tool names;
  three-way validation rejects drift between the set, the HTML, and the
  registration sites.

Replace the placeholder tools and HTML with your domain's implementation.
See ``register_apps`` for the tool registration pattern and
``_SPA_SHELL_HTML`` (DOMAIN-APP-HTML-START block) for the HTML placeholder.
"""

from __future__ import annotations

import logging
import re
from typing import Any

from fastmcp import FastMCP
from fastmcp.apps import AppConfig

try:
    from fastmcp.server.providers.addressing import (
        hash_tool,
        hashed_backend_name,
    )
except ImportError as exc:  # pragma: no cover
    raise ImportError(
        "fastmcp.server.providers.addressing is required for MCP Apps SPA "
        "tool routing. Pin fastmcp>=3.2.4 in pyproject.toml."
    ) from exc

logger = logging.getLogger(__name__)

_APP_NAME = "{{ python_module }}"
_APP_URI = "ui://{{ python_module }}/app.html"

# Single source of truth for app-only tool names.
# Three invariants are enforced automatically:
#   (1) _rewrite_spa_app_tool_calls at module import rejects HTML with zero
#       {{ python_module }}___<name> literals.
#   (2) _rewrite_spa_app_tool_calls rejects literals not in this set.
#   (3) _rewrite_spa_app_tool_calls rejects names in this set absent from HTML.
# _app_tool_meta enforces (2) again at register_apps() call time.
# When adding a tool: add its name here AND add a matching
# {{ python_module }}___<name> literal to the SPA HTML in _SPA_SHELL_HTML.
_APP_TOOL_NAMES: frozenset[str] = frozenset(
    {
        # DOMAIN-APP-TOOL-NAMES-START — add app-only tool names here; kept across copier update.
        "get_status",
        "get_info",
        # DOMAIN-APP-TOOL-NAMES-END
    }
)


def _app_tool_meta(tool_name: str) -> dict[str, Any]:
    """Build the per-tool ``meta`` dict for a fastmcp >=3.2.4 app-only tool."""
    if tool_name not in _APP_TOOL_NAMES:
        raise ValueError(f"Unknown app tool {tool_name!r}; add to _APP_TOOL_NAMES.")
    return {
        "fastmcp": {
            "app": _APP_NAME,
            "_tool_hash": hash_tool(_APP_NAME, tool_name),
        }
    }


def _hashed(tool_name: str) -> str:
    """Return the ``<hash>_<tool_name>`` callable name for an app-only tool."""
    return hashed_backend_name(_APP_NAME, tool_name)


def _rewrite_spa_app_tool_calls(html: str) -> str:
    """Rewrite SPA's ``{{ python_module }}___<tool>`` literals to fastmcp's hash form.

    fastmcp 3.2.4 dropped ``<app>___<tool>`` routing; the dispatcher now
    only accepts ``<hex_hash>_<tool>`` (computed by
    :func:`fastmcp.server.providers.addressing.hashed_backend_name`).
    Substitution happens once at module import so the source HTML stays
    diff-readable while the wire form is already addressed correctly.

    Raises :class:`RuntimeError` if:

    - zero ``{{ python_module }}___<tool>`` literals are found in the HTML;
    - the captured name set doesn't match :data:`_APP_TOOL_NAMES`.
    """
    captured: set[str] = set()

    def _capture(m: re.Match[str]) -> str:
        name = m.group(1)
        captured.add(name)
        return _hashed(name)

    new_html, count = re.subn(
        r"{{ python_module }}___([a-z_]+)",
        _capture,
        html,
    )
    if count == 0:
        raise RuntimeError(
            "SPA rewrite found zero '{{ python_module }}___<tool>' literals — "
            "update _SPA_SHELL_HTML to use the <app>___<tool> source form."
        )
    unexpected = captured - _APP_TOOL_NAMES
    if unexpected:
        raise RuntimeError(
            f"SPA references unknown tools: {sorted(unexpected)}. "
            "Fix the typo in _SPA_SHELL_HTML or add the name to _APP_TOOL_NAMES."
        )
    missing = _APP_TOOL_NAMES - captured
    if missing:
        raise RuntimeError(
            f"SPA doesn't reference declared tools: {sorted(missing)}. "
            "Remove from _APP_TOOL_NAMES or wire the SPA to call them."
        )
    return new_html


# DOMAIN-APP-HTML-START — replace with your real SPA HTML.
# For production SPAs, extract to static/app.html and load via importlib.resources.
# Uses {{ python_module }}___<tool> source literals; _rewrite_spa_app_tool_calls
# rewrites them to the fastmcp >=3.2.4 hash form at module import.
# Kept across copier update.
_SPA_SHELL_HTML = _rewrite_spa_app_tool_calls(
    """\
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<title>{{ human_name }}</title>
<style>
  body { font-family: sans-serif; padding: 1rem; }
  pre { background: #f5f5f5; padding: .5rem; border-radius: 4px; }
  button { margin: .25rem 0; padding: .25rem .75rem; cursor: pointer; }
</style>
</head>
<body>
<h2>{{ human_name }}</h2>
<button id="btn-status">Get status</button>
<button id="btn-info">Get info</button>
<pre id="out">(click a button)</pre>
<script type="module">
async function call(tool, params) {
  try {
    const result = await app.callServerTool(tool, params);
    document.getElementById("out").textContent = JSON.stringify(result, null, 2);
  } catch (e) {
    document.getElementById("out").textContent = "Error: " + e.message;
  }
}
document.getElementById("btn-status").onclick =
  () => call("{{ python_module }}___get_status", {});
document.getElementById("btn-info").onclick =
  () => call("{{ python_module }}___get_info", {});
</script>
</body>
</html>"""
)
# DOMAIN-APP-HTML-END


def register_apps(mcp: FastMCP) -> None:
    """Register MCP Apps resource and app-only tools on *mcp*."""

    @mcp.resource(_APP_URI)
    def _app_shell() -> str:
        return _SPA_SHELL_HTML

    # DOMAIN-APP-TOOLS-START — replace placeholder tools with domain logic.
    # Each app-only tool must use:
    #   meta=_app_tool_meta("<name>")
    #   app=AppConfig(resource_uri=_APP_URI, visibility=["app"])
    # Kept across copier update.

    @mcp.tool(
        meta=_app_tool_meta("get_status"),
        app=AppConfig(resource_uri=_APP_URI, visibility=["app"]),
    )
    async def get_status() -> dict[str, Any]:
        """Return server status (app-only; hidden from the LLM)."""
        return {"status": "ok", "server": "{{ project_name }}"}

    @mcp.tool(
        meta=_app_tool_meta("get_info"),
        app=AppConfig(resource_uri=_APP_URI, visibility=["app"]),
    )
    async def get_info() -> dict[str, Any]:
        """Return server info (app-only; hidden from the LLM)."""
        return {"name": "{{ human_name }}", "version": "0.0.0"}

    # DOMAIN-APP-TOOLS-END
