#!/bin/bash
# Post-install script: create venv and install {{ project_name }} from PyPI.
set -eu

INSTALL_DIR="/opt/{{ project_name }}"
VENV_DIR="${INSTALL_DIR}/venv"
SERVICE_USER="{{ project_name }}"

# Determine package version — set by nfpm via VERSION env var, or read
# from the installed package metadata as fallback.
PKG_VERSION="${VERSION:-}"

# Create install directory
mkdir -p "$INSTALL_DIR"

# Create or update the virtual environment
if [ ! -d "$VENV_DIR" ]; then
    python3 -m venv "$VENV_DIR"
fi

# Upgrade pip and install the package
"${VENV_DIR}/bin/pip" install --quiet --upgrade pip

if [ -n "$PKG_VERSION" ]; then
    "${VENV_DIR}/bin/pip" install --quiet "{{ project_name }}==${PKG_VERSION}"
else
    "${VENV_DIR}/bin/pip" install --quiet "{{ project_name }}"
fi

# Ensure config directory exists
mkdir -p /etc/{{ project_name }}

# Copy example env if no config exists yet
if [ ! -f /etc/{{ project_name }}/env ]; then
    if [ -f /etc/{{ project_name }}/env.example ]; then
        cp /etc/{{ project_name }}/env.example /etc/{{ project_name }}/env
    fi
fi

# Restrict env file permissions — it may contain secrets (tokens, API keys).
if [ -f /etc/{{ project_name }}/env ]; then
    chmod 600 /etc/{{ project_name }}/env
fi

# Reload systemd to pick up the unit file.
# Note: the service is intentionally NOT enabled here — start-on-boot requires
# explicit opt-in by the administrator via: systemctl enable {{ project_name }}
systemctl daemon-reload 2>/dev/null || true

# On upgrade, restart the service if it's already running so the new version is loaded.
if systemctl is-active --quiet {{ project_name }} 2>/dev/null; then
    systemctl restart {{ project_name }}
fi
