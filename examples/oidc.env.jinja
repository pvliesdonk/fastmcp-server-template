# OIDC authentication example
# See docs/guides/authentication.md for setup instructions

{{ env_prefix }}_BASE_URL=https://mcp.example.com
{{ env_prefix }}_OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
{{ env_prefix }}_OIDC_CLIENT_ID=mcp-client
{{ env_prefix }}_OIDC_CLIENT_SECRET=your-client-secret
{{ env_prefix }}_OIDC_JWT_SIGNING_KEY=your-signing-key   # openssl rand -hex 32
{{ env_prefix }}_READ_ONLY=false
